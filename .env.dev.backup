# S3 Administrator - Community Edition
# Copy this file to .env and fill in the values:
#   cp .env.community .env

ENVIRONMENT="COMMUNITY"
NEXT_PUBLIC_EDITION="community"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/s3admin"
DATABASE_URL_DOCKER="postgresql://s3admin:password@db:5432/s3_admin"
POSTGRES_PASSWORD="password"
POSTGRES_PORT="5432"

# Auth secret (required even in community mode for session signing)
# Generate with: openssl rand -base64 32
AUTH_SECRET="dGVzdC1zZWNyZXQtMDEyMzQ1Njc4OWFiY2RlZg==" 
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Local proxy
DOMAIN="localhost"
ROOT_DOMAIN="localhost"
CADDY_SITE_ADDRESSES=":80"

# Encryption keys for S3 credentials stored in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
# Generate with: openssl rand -hex 16
ENCRYPTION_SALT="0123456789abcdef0123456789abcdef"

# Thumbnail generation (generates WebP previews for images and videos)
# Set to "false" to disable thumbnail generation
THUMBNAIL_GENERATION_ENABLED="false"
THUMBNAIL_MAX_WIDTH="480"
AUTH_MODE=multi
NEXT_PUBLIC_AUTH_MODE=multi
SKIP_EDITION_STUBS=true
