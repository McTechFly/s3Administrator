# =============================================================================
#  s3Administrator — Configuration file
# =============================================================================
#
#  Copy this file to `.env` next to your docker-compose.yml and edit the
#  values marked "REQUIRED". Every other setting has a sensible default.
#
#  This is the ONLY file you need to edit to install and run the app.
#
# -----------------------------------------------------------------------------
#  1. Database
# -----------------------------------------------------------------------------
#
#  Point the app at any PostgreSQL 14+ server. On first start the app will
#  create the database (if it does not exist yet) and apply all schema
#  migrations automatically.
#
#  The user must have CREATEDB privileges for the auto-create step. If not,
#  create the database yourself and set AUTO_CREATE_DATABASE=false.
#
DATABASE_URL=postgres://s3admin:change-me@db:5432/s3admin

# Set to false to skip all auto-bootstrap (migrations + create DB) at boot.
AUTO_MIGRATE=true
AUTO_CREATE_DATABASE=true

# Used only by the bundled "db" service in docker-compose.release.yml.
POSTGRES_USER=s3admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=s3admin

# -----------------------------------------------------------------------------
#  2. Authentication & secrets (REQUIRED)
# -----------------------------------------------------------------------------
#
#  Generate each of these with:   openssl rand -base64 48
#  They MUST be stable across restarts, otherwise sessions/credentials break.
#
AUTH_SECRET=change-me-to-a-long-random-string
ENCRYPTION_MASTER_KEY=change-me-to-a-long-random-string
ENCRYPTION_SALT=change-me-to-a-long-random-string

# Public base URL of your deployment (used for OAuth callbacks, emails, etc.).
AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
#  3. Multi-user mode
# -----------------------------------------------------------------------------
#
#  multi  → email + password registration, admin panel, bucket sharing
#  single → single-user mode (no login, legacy community behaviour)
#
AUTH_MODE=multi
NEXT_PUBLIC_AUTH_MODE=multi

# Set to true to disable new public registrations after the first admin
# has signed up. The admin can still invite users from /admin/users.
DISABLE_SIGNUP=false

# -----------------------------------------------------------------------------
#  4. Edition (leave as-is for the self-hosted build)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_EDITION=community
ENVIRONMENT=COMMUNITY
SKIP_EDITION_STUBS=true

# -----------------------------------------------------------------------------
#  5. Optional features
# -----------------------------------------------------------------------------
# Image/video thumbnails (requires ffmpeg in the image — already bundled).
THUMBNAIL_GENERATION_ENABLED=true

# Task engine (background transfers). Leave enabled unless you know better.
TASK_ENGINE_V2=true
TASK_ENGINE_INTERNAL_TOKEN=change-me-to-a-long-random-string

# Lease duration for task claims (30–600s). A worker claims a task for
# this many seconds; if it crashes, another worker picks the task back up
# after the lease expires. Must be longer than the longest atomic step
# your workers perform (big S3 copy, multipart part upload, etc.).
TASK_LOCK_SECONDS=120

# Where to write the application log file inside the container.
SYSTEM_LOG_FILE_PATH=/app/logs/system.log

# -----------------------------------------------------------------------------
#  6. High-availability / cluster
# -----------------------------------------------------------------------------
#
#  Set CLUSTER_MODE=true on every app replica when running multiple instances
#  behind a load balancer (see docker-compose.cluster.yml). This disables the
#  embedded in-process task worker so only the dedicated `worker` service
#  handles background jobs.
#
#  All replicas MUST share: DATABASE_URL, AUTH_SECRET, ENCRYPTION_MASTER_KEY,
#  ENCRYPTION_SALT. Migrations are automatically serialized via a Postgres
#  advisory lock, so simultaneous boots are safe.
#
CLUSTER_MODE=false
