# S3 Administrator - Community Edition
# Copy this file to .env and fill in the values:
#   cp .env.community .env

ENVIRONMENT="COMMUNITY"
NEXT_PUBLIC_EDITION="community"

# Database
DATABASE_URL="postgresql://s3admin:password@localhost:5433/s3_admin"
DATABASE_URL_DOCKER="postgresql://s3admin:password@db:5432/s3_admin"
POSTGRES_PASSWORD="password"
POSTGRES_PORT="5433"

# Auth secret (required even in community mode for session signing)
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Local proxy
DOMAIN="localhost"
ROOT_DOMAIN="localhost"
CADDY_SITE_ADDRESSES=":80"

# Encryption keys for S3 credentials stored in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=""
# Generate with: openssl rand -hex 16
ENCRYPTION_SALT=""
